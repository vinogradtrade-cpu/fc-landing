# /etc/nginx/sites-available/fc-landing.conf
#
# 1) Замени __PUBLIC_HOST__ на боевой домен (например, media-konveyer.ru, www.media-konveyer.ru).
# 2) Скопируй: sudo cp deploy/nginx.fc-landing.conf.example /etc/nginx/sites-available/fc-landing.conf
# 3) Активируй:  sudo ln -s /etc/nginx/sites-available/fc-landing.conf /etc/nginx/sites-enabled/fc-landing.conf
# 4) Проверь:    sudo nginx -t && sudo systemctl reload nginx
# 5) HTTPS:      sudo certbot --nginx -d __PUBLIC_HOST__ -d www.__PUBLIC_HOST__
#                (после certbot блок ниже будет автоматически дополнен listen 443 ssl + редиректом с 80).

server {
    listen 80;
    listen [::]:80;
    server_name __PUBLIC_HOST__ www.__PUBLIC_HOST__;

    # Корень — симлинк на текущий релиз. Переключение релизов атомарно: nginx
    # резолвит симлинк на каждый запрос, перезагрузка не нужна.
    root /opt/fc-landing/current;
    index index.html;

    charset utf-8;
    server_tokens off;
    client_max_body_size 1m;

    # Спец-маршруты до общего блока статики.
    location = /robots.txt {
        access_log off;
        try_files /robots.txt =404;
    }
    location = /sitemap.xml {
        access_log off;
        types { } default_type application/xml;
        try_files /sitemap.xml =404;
    }
    location = /favicon.ico {
        access_log off;
        log_not_found off;
        try_files /assets/favicon.webp =404;
    }

    # Долгий кэш для иммутабельных ассетов (картинки, шрифты, фоны).
    location ~* ^/(assets|backgrounds)/.+\.(webp|avif|png|jpe?g|gif|svg|ico|woff2?|ttf|otf|eot)$ {
        expires 30d;
        add_header Cache-Control "public, max-age=2592000, immutable";
        access_log off;
        try_files $uri =404;
    }

    # Скрипт лендинга — короткий кэш, чтобы правки доезжали.
    location ~* \.(js|css)$ {
        expires 1h;
        add_header Cache-Control "public, max-age=3600";
        try_files $uri =404;
    }

    # HTML — без кэша, всегда свежий.
    location / {
        add_header Cache-Control "no-store, no-cache, must-revalidate";
        try_files $uri $uri/ $uri.html /index.html;
    }

    # Скрытые файлы — никогда не отдавать.
    location ~ /\.(?!well-known) {
        deny all;
        access_log off;
        log_not_found off;
    }

    # gzip (br ставится отдельным модулем, не во всех сборках есть).
    gzip on;
    gzip_vary on;
    gzip_min_length 512;
    gzip_proxied any;
    gzip_types
        text/plain
        text/css
        text/xml
        application/xml
        application/json
        application/javascript
        image/svg+xml
        font/woff2;

    access_log /var/log/nginx/fc-landing.access.log;
    error_log  /var/log/nginx/fc-landing.error.log;
}
